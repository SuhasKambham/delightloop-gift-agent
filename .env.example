# Copy to .env and fill in values. Never commit .env to Git.

# Required — LLM (Groq free tier: https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Required — product search (SerpAPI free tier: https://serpapi.com)
SERPAPI_KEY=your_serpapi_key_here

# Optional — LangSmith tracing (https://smith.langchain.com)
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=delightloop-gift-agent

# Optional — Streamlit UI (local dev with separate API server)
# API_URL=http://127.0.0.1:8000
# GIFT_AGENT_DIRECT=false

# Hugging Face Streamlit Space: set the three required/optional keys as Space Secrets.
# GIFT_AGENT_DIRECT defaults to true when API_URL is unset.
